import torch
import math
from scipy.linalg import null_space

def bernstein_matrix(x, N):
    n = N-1
    return torch.stack([
        math.comb(n, k)*(x**k)*(1 - x)**(n-k)
        for k in range(n+1)
    ], dim=1)
def implicit_bernstein_matrix(x, N):
    B = bernstein_matrix(x, N)
    implicit_B = torch.tensor(null_space(B.T)).T
    return implicit_B

def rainbow(i):
